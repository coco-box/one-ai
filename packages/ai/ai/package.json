{
  "name": "@coco-box/ai",
  "version": "0.0.1",
  "description": "AI SDK 封装与 UI 消息流工具库",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./ui": {
      "import": "./dist/ui/index.js",
      "default": "./dist/ui/index.js",
      "types": "./dist/ui/index.d.ts"
    },
    "./ui-message-stream": {
      "import": "./dist/ui-message-stream/index.js",
      "default": "./dist/ui-message-stream/index.js",
      "types": "./dist/ui-message-stream/index.d.ts"
    },
    "./util": {
      "import": "./dist/util/index.js",
      "default": "./dist/util/index.js",
      "types": "./dist/util/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .js,.cjs,.mjs,.ts,.tsx --fix --ignore-path .gitignore",
    "test": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ai-sdk/provider": "2.0.0",
    "@ai-sdk/provider-utils": "3.0.1",
    "ai": "5.0.8",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "rimraf": "^5.0.5",
    "typescript": "^5.7.3",
    "vite": "^5.0.12",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^1.2.2",
    "eslint": "^9.33.0",
    "@coco-box/ai-eslint-config": "workspace:*"
  }
}
