{
  "name": "@coco-box/ai-vue-2",
  "version": "0.0.1",
  "description": "基于 Vue 2.6+ 和 Composition API 的 AI Chat 绑定与工具",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .js,.cjs,.mjs,.ts,.tsx,.vue --fix --ignore-path .gitignore",
    "test": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@coco-box/ai": "workspace:*"
  },
  "peerDependencies": {
    "@vue/composition-api": ">=1.6.0",
    "vue": ">=2.6.0"
  },
  "devDependencies": {
    "@vue/composition-api": "1.7.1",
    "vue": "2.6.14",
    "@types/node": "^20.11.5",
    "@types/vue": "^2.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.7.3",
    "vite": "^5.0.12",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^1.2.2",
    "eslint": "^9.33.0",
    "@coco-box/ai-eslint-config": "workspace:*"
  }
}